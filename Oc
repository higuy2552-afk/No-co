<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ปิตซึม กาเซีย | Pitsam Gacia - Shadow Patron</title>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Sarabun:wght@300;400;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Sarabun', sans-serif;
            background: linear-gradient(135deg, #0c0c0c 0%, #1a1a2e 50%, #16213e 100%);
            color: #ffffff;
            overflow-x: hidden;
            line-height: 1.6;
            position: relative;
        }

        /* Animated Background Particles */
        .particles {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 0;
            overflow: hidden;
        }

        .particle {
            position: absolute;
            width: 4px;
            height: 4px;
            background: rgba(255, 105, 180, 0.5);
            border-radius: 50%;
            animation: float-particle 15s infinite;
            box-shadow: 0 0 10px rgba(255, 105, 180, 0.8);
        }

        @keyframes float-particle {
            0%, 100% {
                transform: translateY(100vh) rotate(0deg);
                opacity: 0;
            }
            10% {
                opacity: 1;
            }
            90% {
                opacity: 1;
            }
            100% {
                transform: translateY(-100vh) rotate(720deg);
                opacity: 0;
            }
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar {
            width: 12px;
        }

        ::-webkit-scrollbar-track {
            background: #0c0c0c;
        }

        ::-webkit-scrollbar-thumb {
            background: linear-gradient(180deg, #ff69b4 0%, #ff1493 100%);
            border-radius: 6px;
            border: 2px solid #0c0c0c;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: linear-gradient(180deg, #ff1493 0%, #c71585 100%);
        }

        /* Scroll Progress Bar */
        .scroll-progress {
            position: fixed;
            top: 0;
            left: 0;
            height: 3px;
            background: linear-gradient(90deg, #ff69b4, #ff1493, #ff69b4);
            z-index: 9999;
            width: 0%;
            transition: width 0.1s;
            box-shadow: 0 0 10px rgba(255, 105, 180, 0.8);
        }

        /* Navigation */
        nav {
            position: fixed;
            top: 0;
            width: 100%;
            background: rgba(12, 12, 12, 0.98);
            backdrop-filter: blur(20px);
            z-index: 1000;
            padding: 15px 0;
            border-bottom: 2px solid rgba(255, 105, 180, 0.3);
            box-shadow: 0 5px 30px rgba(255, 20, 147, 0.3);
            transition: all 0.3s ease;
        }

        nav.scrolled {
            padding: 10px 0;
            background: rgba(12, 12, 12, 0.99);
        }

        nav ul {
            list-style: none;
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            gap: 25px;
            padding: 0 20px;
        }

        nav a {
            color: #fff;
            text-decoration: none;
            font-family: 'Cinzel', serif;
            font-weight: 600;
            font-size: 13px;
            transition: all 0.3s ease;
            position: relative;
            padding: 8px 18px;
            border-radius: 25px;
            display: inline-block;
        }

        nav a::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(135deg, #ff69b4 0%, #ff1493 100%);
            border-radius: 25px;
            opacity: 0;
            transition: opacity 0.3s ease;
            z-index: -1;
            transform: scale(0.8);
        }

        nav a:hover::before,
        nav a.active::before {
            opacity: 1;
            transform: scale(1);
        }

        nav a:hover,
        nav a.active {
            color: #fff;
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(255, 105, 180, 0.4);
        }

        /* Hero Section */
        .hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 140px 20px 100px;
            position: relative;
            z-index: 1;
            overflow: hidden;
        }

        .hero::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: 
                radial-gradient(ellipse at 20% 50%, rgba(255, 105, 180, 0.15) 0%, transparent 50%),
                radial-gradient(ellipse at 80% 50%, rgba(255, 20, 147, 0.1) 0%, transparent 50%);
            pointer-events: none;
        }

        .hero-container {
            max-width: 1200px;
            width: 100%;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 80px;
            align-items: center;
            position: relative;
            z-index: 2;
        }

        .hero-image {
            position: relative;
            animation: hero-float 6s ease-in-out infinite;
        }

        @keyframes hero-float {
            0%, 100% { transform: translateY(0px) rotate(0deg); }
            50% { transform: translateY(-20px) rotate(1deg); }
        }

        .hero-image-wrapper {
            position: relative;
            border-radius: 30px;
            overflow: hidden;
            box-shadow: 
                0 30px 80px rgba(255, 20, 147, 0.4),
                0 0 0 2px rgba(255, 105, 180, 0.5);
        }

        .hero-image img {
            width: 100%;
            display: block;
            transition: transform 0.5s ease;
        }

        .hero-image-wrapper:hover img {
            transform: scale(1.05);
        }

        .hero-image-glow {
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255, 105, 180, 0.3) 0%, transparent 70%);
            animation: glow-rotate 10s linear infinite;
            pointer-events: none;
        }

        @keyframes glow-rotate {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .hero-content {
            animation: fade-in-up 1s ease;
        }

        @keyframes fade-in-up {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .hero-content h1 {
            font-family: 'Cinzel', serif;
            font-size: 4em;
            margin-bottom: 15px;
            background: linear-gradient(135deg, #fff 0%, #ff69b4 50%, #ff1493 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            line-height: 1.2;
            animation: text-glow 3s ease-in-out infinite;
        }

        @keyframes text-glow {
            0%, 100% { filter: drop-shadow(0 0 20px rgba(255, 105, 180, 0.5)); }
            50% { filter: drop-shadow(0 0 40px rgba(255, 105, 180, 0.8)); }
        }

        .hero-content .subtitle {
            font-size: 1.6em;
            color: #ff69b4;
            margin-bottom: 25px;
            font-style: italic;
            font-family: 'Cinzel', serif;
            animation: pulse 2s ease-in-out infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.7; }
        }

        .hero-content .info-text {
            font-size: 1.1em;
            color: #ccc;
            margin-bottom: 30px;
            line-height: 1.8;
        }

        .hero-content .quote {
            font-size: 1.3em;
            color: #fff;
            border-left: 5px solid #ff69b4;
            padding-left: 25px;
            margin-top: 35px;
            font-style: italic;
            background: linear-gradient(90deg, rgba(255, 105, 180, 0.1) 0%, transparent 100%);
            padding: 20px 25px;
            border-radius: 0 15px 15px 0;
            position: relative;
            overflow: hidden;
        }

        .hero-content .quote::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 105, 180, 0.2), transparent);
            animation: quote-shine 3s ease-in-out infinite;
        }

        @keyframes quote-shine {
            0%, 100% { left: -100%; }
            50% { left: 100%; }
        }

        /* Section Styles */
        section {
            padding: 120px 20px;
            position: relative;
            z-index: 1;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        .section-title {
            font-family: 'Cinzel', serif;
            font-size: 3em;
            text-align: center;
            margin-bottom: 70px;
            position: relative;
            background: linear-gradient(135deg, #fff 0%, #ff69b4 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            display: inline-block;
            left: 50%;
            transform: translateX(-50%);
        }

        .section-title::after {
            content: '';
            position: absolute;
            bottom: -20px;
            left: 50%;
            transform: translateX(-50%);
            width: 200px;
            height: 4px;
            background: linear-gradient(90deg, transparent 0%, #ff69b4 50%, transparent 100%);
            border-radius: 2px;
            animation: title-line 2s ease-in-out infinite;
        }

        @keyframes title-line {
            0%, 100% { width: 200px; opacity: 1; }
            50% { width: 250px; opacity: 0.7; }
        }

        /* Glass Cards */
        .glass-card {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 105, 180, 0.2);
            border-radius: 25px;
            padding: 45px;
            margin-bottom: 35px;
            box-shadow: 
                0 10px 40px rgba(0, 0, 0, 0.3),
                inset 0 0 0 1px rgba(255, 255, 255, 0.05);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            position: relative;
            overflow: hidden;
        }

        .glass-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 105, 180, 0.1), transparent);
            transition: left 0.8s ease;
        }

        .glass-card:hover::before {
            left: 100%;
        }

        .glass-card:hover {
            transform: translateY(-8px) scale(1.01);
            border-color: rgba(255, 105, 180, 0.5);
            box-shadow: 
                0 20px 60px rgba(255, 20, 147, 0.3),
                inset 0 0 0 1px rgba(255, 255, 255, 0.1);
        }

        /* Info Grid */
        .info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 25px;
            margin-top: 40px;
        }

        .info-item {
            background: rgba(255, 105, 180, 0.05);
            padding: 28px;
            border-radius: 18px;
            border-left: 5px solid #ff69b4;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            position: relative;
            overflow: hidden;
        }

        .info-item::after {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255, 105, 180, 0.1) 0%, transparent 70%);
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .info-item:hover::after {
            opacity: 1;
        }

        .info-item:hover {
            background: rgba(255, 105, 180, 0.12);
            transform: translateX(12px) scale(1.02);
            border-left-width: 7px;
            box-shadow: 0 5px 20px rgba(255, 105, 180, 0.2);
        }

        .info-item h3 {
            color: #ff69b4;
            font-family: 'Cinzel', serif;
            margin-bottom: 12px;
            font-size: 1.2em;
            position: relative;
        }

        .info-item p, .info-item li {
            color: #ddd;
            font-size: 1em;
            position: relative;
        }

        .info-item ul {
            list-style: none;
            padding-left: 0;
        }

        .info-item li {
            padding: 8px 0;
            padding-left: 25px;
            position: relative;
        }

        .info-item li::before {
            content: '❥';
            color: #ff69b4;
            position: absolute;
            left: 0;
            transition: transform 0.3s ease;
        }

        .info-item li:hover::before {
            transform: scale(1.3) rotate(15deg);
        }

        /* Personality Section */
        .personality-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 40px;
        }

        .personality-column h3 {
            font-family: 'Cinzel', serif;
            font-size: 1.9em;
            margin-bottom: 30px;
            color: #ff69b4;
            display: flex;
            align-items: center;
            gap: 15px;
            position: relative;
            padding-bottom: 15px;
        }

        .personality-column h3::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100px;
            height: 3px;
            background: linear-gradient(90deg, #ff69b4, transparent);
        }

        .personality-column ul {
            list-style: none;
        }

        .personality-column li {
            padding: 18px 25px;
            margin-bottom: 18px;
            background: rgba(255, 255, 255, 0.03);
            border-radius: 12px;
            border-left: 4px solid #ff69b4;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            position: relative;
            padding-left: 55px;
            cursor: default;
        }

        .personality-column li::before {
            content: attr(data-icon);
            position: absolute;
            left: 22px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 1.6em;
            transition: transform 0.3s ease;
        }

        .personality-column li:hover {
            background: rgba(255, 105, 180, 0.15);
            transform: translateX(15px) scale(1.02);
            border-left-width: 6px;
            box-shadow: 0 5px 20px rgba(255, 105, 180, 0.2);
        }

        .personality-column li:hover::before {
            transform: translateY(-50%) scale(1.3);
        }

        .external { border-left-color: #00ff88; }
        .external::before { content: '✨' !important; }
        
        .internal { border-left-color: #ff1493; }
        .internal::before { content: '🖤' !important; }

        /* Business Deal Section */
        .deal-section {
            background: 
                radial-gradient(ellipse at center, rgba(255, 105, 180, 0.08) 0%, transparent 70%);
            position: relative;
        }

        .deal-container {
            max-width: 1000px;
            margin: 0 auto;
        }

        .deal-box {
            background: linear-gradient(135deg, rgba(255, 105, 180, 0.15) 0%, rgba(255, 20, 147, 0.08) 100%);
            border: 2px solid rgba(255, 105, 180, 0.5);
            border-radius: 35px;
            padding: 60px;
            position: relative;
            overflow: hidden;
            box-shadow: 0 25px 80px rgba(255, 20, 147, 0.3);
        }

        .deal-box::before {
            content: '✦';
            position: absolute;
            top: 25px;
            right: 35px;
            font-size: 4em;
            color: rgba(255, 105, 180, 0.2);
            animation: rotate 15s linear infinite;
        }

        @keyframes rotate {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        .deal-quote {
            font-size: 1.5em;
            font-style: italic;
            text-align: center;
            color: #fff;
            margin: 35px 0;
            padding: 35px;
            background: rgba(0, 0, 0, 0.4);
            border-radius: 20px;
            border-left: 6px solid #ff69b4;
            border-right: 6px solid #ff69b4;
            position: relative;
            line-height: 1.8;
            transition: all 0.3s ease;
        }

        .deal-quote:hover {
            background: rgba(0, 0, 0, 0.5);
            transform: scale(1.02);
            box-shadow: 0 10px 30px rgba(255, 105, 180, 0.2);
        }

        .deal-quote::before,
        .deal-quote::after {
            content: '"';
            font-size: 3em;
            color: #ff69b4;
            position: absolute;
            opacity: 0.5;
        }

        .deal-quote::before {
            top: 15px;
            left: 25px;
        }

        .deal-quote::after {
            bottom: -15px;
            right: 25px;
        }

        .quality-points {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 30px;
            margin-top: 45px;
        }

        .quality-card {
            background: rgba(255, 255, 255, 0.05);
            padding: 35px;
            border-radius: 20px;
            border: 1px solid rgba(255, 105, 180, 0.3);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            position: relative;
            overflow: hidden;
        }

        .quality-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 4px;
            background: linear-gradient(90deg, #ff69b4, #ff1493);
            transform: scaleX(0);
            transition: transform 0.4s ease;
        }

        .quality-card:hover::before {
            transform: scaleX(1);
        }

        .quality-card:hover {
            background: rgba(255, 105, 180, 0.18);
            transform: translateY(-10px) scale(1.03);
            border-color: rgba(255, 105, 180, 0.6);
            box-shadow: 0 15px 40px rgba(255, 105, 180, 0.3);
        }

        .quality-card h4 {
            color: #ff69b4;
            font-family: 'Cinzel', serif;
            margin-bottom: 18px;
            font-size: 1.3em;
        }

        .quality-card small {
            color: #fff;
            font-weight: 600;
        }

        /* Quotes Section */
        .quotes-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(380px, 1fr));
            gap: 30px;
        }

        .quote-card {
            background: rgba(255, 105, 180, 0.06);
            padding: 40px;
            border-radius: 25px;
            border-left: 6px solid #ff69b4;
            position: relative;
            font-style: italic;
            font-size: 1.15em;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            cursor: default;
        }

        .quote-card::before {
            content: '"';
            font-size: 5em;
            color: rgba(255, 105, 180, 0.2);
            position: absolute;
            top: -15px;
            left: 25px;
            font-family: Georgia, serif;
            transition: all 0.3s ease;
        }

        .quote-card:hover {
            background: rgba(255, 105, 180, 0.18);
            transform: translateY(-8px) scale(1.03);
            box-shadow: 0 15px 40px rgba(255, 105, 180, 0.3);
        }

        .quote-card:hover::before {
            color: rgba(255, 105, 180, 0.4);
            transform: scale(1.1);
        }

        /* Footer */
        footer {
            background: rgba(0, 0, 0, 0.9);
            text-align: center;
            padding: 80px 20px;
            border-top: 3px solid rgba(255, 105, 180, 0.4);
            position: relative;
            z-index: 1;
        }

        footer::before {
            content: '❥';
            position: absolute;
            top: -25px;
            left: 50%;
            transform: translateX(-50%);
            background: linear-gradient(135deg, #0c0c0c 0%, #1a1a2e 100%);
            width: 60px;
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            border: 3px solid #ff69b4;
            color: #ff69b4;
            font-size: 1.8em;
            box-shadow: 0 5px 20px rgba(255, 105, 180, 0.4);
            animation: footer-icon-pulse 2s ease-in-out infinite;
        }

        @keyframes footer-icon-pulse {
            0%, 100% { transform: translateX(-50%) scale(1); }
            50% { transform: translateX(-50%) scale(1.1); }
        }

        footer .final-quote {
            font-family: 'Cinzel', serif;
            font-size: 1.6em;
            color: #ff69b4;
            margin-bottom: 25px;
            font-style: italic;
            animation: fade-in-up 1s ease;
        }

        /* Responsive */
        @media (max-width: 968px) {
            .hero-container {
                grid-template-columns: 1fr;
                text-align: center;
                gap: 50px;
            }

            .hero-content h1 {
                font-size: 2.8em;
            }

            .hero-content .quote {
                border-left: none;
                border-top: 5px solid #ff69b4;
                padding-left: 25px;
                padding-top: 25px;
                border-radius: 0 0 15px 15px;
            }

            .personality-grid {
                grid-template-columns: 1fr;
            }

            .quotes-grid {
                grid-template-columns: 1fr;
            }

            .deal-box {
                padding: 45px 30px;
            }

            .section-title {
                font-size: 2.3em;
            }

            nav ul {
                gap: 12px;
            }

            nav a {
                font-size: 11px;
                padding: 6px 12px;
            }
        }

        @media (max-width: 600px) {
            .hero-content h1 {
                font-size: 2.2em;
            }

            .section-title {
                font-size: 1.8em;
            }

            .info-grid {
                grid-template-columns: 1fr;
            }

            .glass-card {
                padding: 30px 20px;
            }

            .quality-points {
                grid-template-columns: 1fr;
            }
        }

        /* Animation Classes */
        .fade-in {
            opacity: 0;
            transform: translateY(40px);
            transition: all 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .fade-in.visible {
            opacity: 1;
            transform: translateY(0);
        }

        /* Loading Animation */
        .loading {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, #0c0c0c 0%, #1a1a2e 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 99999;
            transition: opacity 0.6s ease, visibility 0.6s ease;
        }

        .loading.hidden {
            opacity: 0;
            visibility: hidden;
            pointer-events: none;
        }

        .loading-content {
            text-align: center;
        }

        .loading-text {
            font-family: 'Cinzel', serif;
            font-size: 2.5em;
            color: #ff69b4;
            animation: loading-pulse 1.5s ease-in-out infinite;
            margin-top: 20px;
        }

        .loading-spinner {
            width: 80px;
            height: 80px;
            border: 4px solid rgba(255, 105, 180, 0.2);
            border-top-color: #ff69b4;
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin: 0 auto;
            box-shadow: 0 0 30px rgba(255, 105, 180, 0.4);
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        @keyframes loading-pulse {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.6; transform: scale(0.95); }
        }

        /* Back to Top Button */
        .back-to-top {
            position: fixed;
            bottom: 30px;
            right: 30px;
            width: 50px;
            height: 50px;
